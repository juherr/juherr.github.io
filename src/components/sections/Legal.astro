---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const l = ui[lang].legal;
---

<section class="mx-auto max-w-site border-b border-border px-8 pb-6 pt-[clamp(48px,6vw,80px)]">
  <div class="mb-[18px] font-mono text-[12px] uppercase tracking-[0.14em] text-accent">{l.kicker}</div>
  <h1 class="m-0 mb-[22px] max-w-[760px] font-display text-[clamp(34px,4.6vw,52px)] font-semibold leading-[1.06] tracking-[-0.02em]">{l.title}</h1>
  <p class="m-0 font-mono text-[13px] text-muted">{l.updated}</p>
</section>

<section class="mx-auto max-w-[760px] px-8 pb-[72px] pt-[clamp(32px,4vw,48px)]">
  <div class="flex flex-col gap-10">
    {l.sections.map((s) => (
      <div>
        <h2 class="m-0 mb-4 font-display text-[21px] font-semibold tracking-[-0.01em]">{s.heading}</h2>
        <div class="flex flex-col gap-[10px]">
          {s.body.map((p) => (
            <p class="m-0 text-[15px] leading-[1.6] text-muted">{p}</p>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
