---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = ui[lang].community;
---

<section class="border-t border-border bg-surface">
  <div class="mx-auto max-w-site px-8 py-[clamp(56px,7vw,88px)]">
    <div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-accent">{c.kicker}</div>
    <h2 class="m-0 mb-[14px] font-display text-[clamp(26px,3.2vw,34px)] font-semibold tracking-[-0.015em]">{c.title}</h2>
    <p class="m-0 mb-10 max-w-[620px] text-[15px] leading-[1.6] text-muted">{c.intro}</p>
    <div class="grid grid-cols-[repeat(auto-fit,minmax(255px,1fr))] gap-5">
      {c.items.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener"
          class="flex flex-col rounded-[14px] border border-border bg-bg p-[26px] text-inherit no-underline transition-colors hover:border-blue"
        >
          <div class="mb-[10px] flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="m-0 font-display text-[19px] font-semibold">{item.name}</h3>
            <span aria-hidden="true" class="text-[14px] font-semibold text-blue">↗</span>
          </div>
          <div class="mb-[10px] font-mono text-[11.5px] uppercase tracking-[0.08em] text-accent">{item.role}</div>
          <p class="m-0 text-[14px] leading-[1.55] text-muted">{item.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>
