---
import { ui, type Lang } from '../../i18n/ui';
import { getProjects, projectHref, isExternal } from '../../lib/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const p = t.projets;

const projects = await getProjects(lang);
const visitLabel = lang === 'fr' ? 'Voir le projet' : 'Visit the project';

// The featured EVSE/CSMS project drives the example case-study sheet.
const fiche = projects.find((pr) => pr.data.featured && pr.data.context) ?? projects[0];
const ficheBlocks = fiche
  ? [
      { label: lang === 'fr' ? 'Contexte' : 'Context', text: fiche.data.context },
      { label: t.labels.role, text: fiche.data.role },
      { label: lang === 'fr' ? 'Réalisation' : 'Delivery', text: fiche.data.delivery },
      { label: t.labels.impact, text: fiche.data.impactDetail },
    ].filter((b) => Boolean(b.text))
  : [];

const chip = 'rounded-md border border-border bg-surface-2 px-[8px] py-[3px] font-mono text-[11px] text-ink';
---

<!-- Intro -->
<section class="mx-auto max-w-site border-b border-border px-8 pb-6 pt-[clamp(48px,6vw,80px)]">
  <div class="mb-[18px] font-mono text-[12px] uppercase tracking-[0.14em] text-accent">{p.kicker}</div>
  <h1 class="m-0 mb-[22px] max-w-[760px] font-display text-[clamp(34px,4.6vw,52px)] font-semibold leading-[1.06] tracking-[-0.02em]">{p.title}</h1>
  <p class="m-0 max-w-[660px] text-[clamp(16px,1.6vw,19px)] leading-[1.6] text-muted">{p.intro}</p>
</section>

<!-- Project grid -->
<section class="mx-auto max-w-site px-8 py-12">
  <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-5">
    {projects.map((pr) => {
      const ext = isExternal(pr);
      return (
        <a
          href={projectHref(pr, lang)}
          target={ext ? '_blank' : undefined}
          rel={ext ? 'noopener' : undefined}
          class="flex flex-col rounded-[14px] border border-border bg-surface p-[26px] text-inherit no-underline transition-colors hover:border-blue"
        >
          <div class="mb-[14px] flex items-center justify-between gap-[10px]">
            <span class="rounded-md border border-blue-soft bg-blue-soft px-[9px] py-1 font-mono text-[11px] uppercase tracking-[0.06em] text-blue">{pr.data.domain}</span>
            <span class="font-mono text-[12px] font-medium text-accent">{pr.data.impact}</span>
          </div>
          <h2 class="m-0 mb-[10px] font-display text-[20px] font-semibold tracking-[-0.01em]">{pr.data.title}</h2>
          <p class="m-0 mb-4 flex-1 text-[14px] leading-[1.55] text-muted">{pr.data.summary}</p>
          <div class="mb-[14px] font-mono text-[11.5px] leading-[1.5] text-muted">
            <span class="text-ink">{t.labels.role} :</span> {pr.data.role}
          </div>
          <div class="mb-4 flex flex-wrap gap-[6px]">
            {pr.data.techs.slice(0, 3).map((tg) => <span class={chip}>{tg}</span>)}
          </div>
          <span class="text-[14px] font-semibold text-blue">{ext ? visitLabel : p.caseStudyCta} →</span>
        </a>
      );
    })}
  </div>
</section>

<!-- Example case-study sheet -->
{fiche && (
  <section class="border-t border-border bg-surface">
    <div class="mx-auto max-w-site px-8 py-[clamp(48px,6vw,72px)]">
      <div class="mb-[18px] font-mono text-[12px] uppercase tracking-[0.12em] text-accent">{p.ficheKicker}</div>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-10">
        <div>
          <span class="rounded-md border border-blue-soft bg-blue-soft px-[9px] py-1 font-mono text-[11px] uppercase tracking-[0.06em] text-blue">{fiche.data.domain}</span>
          <h2 class="m-0 mb-4 mt-[18px] font-display text-[clamp(24px,3vw,32px)] font-semibold tracking-[-0.015em]">{fiche.data.title}</h2>
          <p class="m-0 mb-6 text-[16px] leading-[1.6] text-muted">{fiche.data.summary}</p>
          <div class="flex flex-wrap gap-[7px]">
            {fiche.data.techs.map((tg) => (
              <span class="rounded-[7px] border border-border bg-surface-2 px-[10px] py-[5px] font-mono text-[11.5px] text-ink">{tg}</span>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-[2px]">
          {ficheBlocks.map((bl) => (
            <div class="border-t border-border py-[18px]">
              <div class="mb-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">{bl.label}</div>
              <p class="m-0 text-[15px] leading-[1.55] text-ink">{bl.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}
