---
import { ui, type Lang } from '../../i18n/ui';
import ProofPill from '../ProofPill.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const e = ui[lang].expertise;
const techLabel = lang === 'fr' ? 'Transverse' : 'Cross-cutting';
const propLabel = lang === 'fr' ? 'Client confidentiel' : 'Confidential client';
const onRequest = lang === 'fr' ? 'démo sur demande' : 'on request';
const exploreLabel = lang === 'fr' ? 'prototype — en exploration' : 'prototype — exploring';
---

<section class="mx-auto max-w-site border-b border-border px-8 pb-6 pt-[clamp(48px,6vw,80px)]">
  <div class="mb-[18px] font-mono text-[12px] uppercase tracking-[0.14em] text-accent">{e.kicker}</div>
  <h1 class="m-0 mb-[22px] max-w-[760px] font-display text-[clamp(34px,4.6vw,52px)] font-semibold leading-[1.06] tracking-[-0.02em]">{e.title}</h1>
  <p class="m-0 max-w-[660px] text-[clamp(16px,1.6vw,19px)] leading-[1.6] text-muted [text-wrap:pretty]">{e.intro}</p>
</section>

<section class="mx-auto max-w-site px-8 pb-16 pt-2">
  <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-8 border-b border-border py-10">
    <div>
      <div class="mb-[14px] font-mono text-[13px] font-semibold text-accent">{e.chain.num}</div>
      <h2 class="m-0 mb-[14px] font-display text-[clamp(22px,2.6vw,28px)] font-semibold tracking-[-0.015em]">{e.chain.title}</h2>
      <p class="m-0 max-w-[380px] text-[15px] leading-[1.6] text-muted">{e.chain.tagline}</p>
    </div>
    <div class="flex flex-col gap-6 border-l border-border pl-7">
      {e.chain.links.map((link) => (
        <div>
          <div class="mb-[8px] flex flex-wrap items-center gap-[10px]">
            <span class="font-mono text-[12px] font-semibold text-blue">{link.num}</span>
            <h3 class="m-0 font-display text-[17px] font-semibold tracking-[-0.01em]">{link.title}</h3>
            {link.status === 'exploration' && (
              <span class="rounded-[4px] border border-border bg-surface-2 px-[6px] py-[2px] font-mono text-[10px] uppercase tracking-[0.06em] text-muted">{exploreLabel}</span>
            )}
          </div>
          <p class="m-0 mb-[12px] max-w-[480px] text-[13.5px] leading-[1.5] text-muted">{link.tagline}</p>
          <div class="flex flex-wrap gap-2">
            {link.proofs.map((p) => <ProofPill proof={p} label={onRequest} />)}
          </div>
        </div>
      ))}
    </div>
  </div>
  {e.axes.map((ax) => (
    <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-8 border-b border-border py-10">
      <div>
        <div class="mb-[14px] font-mono text-[13px] font-semibold text-accent">{ax.num}</div>
        <h2 class="m-0 mb-[14px] font-display text-[clamp(22px,2.6vw,28px)] font-semibold tracking-[-0.015em]">{ax.title}</h2>
        <p class="m-0 max-w-[380px] text-[15px] leading-[1.6] text-muted">{ax.text}</p>
      </div>
      <div class="flex flex-col gap-5">
        {ax.groups.map((g) => (
          <div>
            <div class="mb-[10px] font-mono text-[11px] uppercase tracking-[0.12em] text-muted">{g.label}</div>
            <div class="flex flex-wrap gap-2">
              {g.proofs.map((p) => <ProofPill proof={p} label={propLabel} />)}
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
  <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-8 border-b border-border py-10">
    <div>
      <div class="mb-[14px] font-mono text-[13px] font-semibold uppercase tracking-[0.06em] text-blue">{techLabel}</div>
      <h2 class="m-0 mb-[14px] font-display text-[clamp(22px,2.6vw,28px)] font-semibold tracking-[-0.015em]">{e.techTitle}</h2>
      <p class="m-0 max-w-[380px] text-[15px] leading-[1.6] text-muted">{e.techText}</p>
    </div>
    <div class="flex flex-wrap content-start gap-2">
      {e.tech.map((cap) => (
        <span class="rounded-[7px] border border-border bg-surface-2 px-3 py-[7px] font-mono text-[12.5px] text-ink">{cap}</span>
      ))}
    </div>
  </div>
  <p class="m-0 mt-7 font-mono text-[13px] text-muted">{e.note}</p>
</section>
