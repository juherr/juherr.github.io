---
import { ui, type Lang } from '../i18n/ui';
import { site, mailto } from '../config/site';

interface Props {
  lang: Lang;
  id?: string;
}
const { lang, id } = Astro.props;
const t = ui[lang].home.final;
---

<section id={id} class="mx-auto max-w-site px-8 py-[clamp(40px,5vw,64px)]">
  <div
    class="relative grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] items-center gap-8 overflow-hidden rounded-[18px] bg-ink p-[clamp(36px,5vw,56px)] dark:bg-surface-2 dark:border dark:border-border"
  >
    <div class="relative z-10">
      <h2 class="m-0 mb-4 font-display text-[clamp(24px,3vw,32px)] font-semibold leading-[1.18] tracking-[-0.015em] text-white">
        {t.title}
      </h2>
      <p class="m-0 max-w-[560px] text-[16px] leading-[1.55] text-[#c3cedb]">{t.text}</p>
    </div>
    <div class="relative z-10 flex flex-wrap gap-[14px] justify-self-start">
      <a
        href={mailto}
        class="rounded-[9px] bg-accent px-6 py-[14px] text-[15px] font-semibold text-on-accent no-underline"
      >
        {t.ctaPrimary}
      </a>
      <a
        href={site.cvUrl}
        target="_blank"
        rel="noopener"
        class="rounded-[9px] border border-[#38495a] bg-transparent px-6 py-[14px] text-[15px] font-semibold text-white no-underline"
      >
        {t.ctaSecondary}
      </a>
    </div>
  </div>
</section>
